<Window x:Class="SolutionRevitAPI.WPF.Views.TagModeV"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SolutionRevitAPI.WPF.Views"
        mc:Ignorable="d"
        Width="350" Height="150" Name="wd" Title="Creat tag" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Height="50" Width="110" Content="Tag an Element" Padding="8" Command="{Binding TagCommand}" CommandParameter="{x:Reference Name=wd}"></Button>
        <Button Grid.Column="1" Height="50" Width="110" Content="Tag by Category" Padding="8" Command="{Binding TagAllCommand}" CommandParameter="{x:Reference Name=wd}"></Button>
    </Grid>
</Window>