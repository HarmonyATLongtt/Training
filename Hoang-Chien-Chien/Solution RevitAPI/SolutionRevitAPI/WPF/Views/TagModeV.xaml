<Window
    x:Class="SolutionRevitAPI.WPF.Views.TagModeV"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SolutionRevitAPI.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Name="wd"
    Title="Creat tag"
    Width="350"
    Height="150"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button
            Grid.Column="0"
            Width="110"
            Height="50"
            Padding="8"
            Command="{Binding TagCommand}"
            CommandParameter="{x:Reference Name=wd}"
            Content="Tag an Element" />
        <Button
            Grid.Column="1"
            Width="110"
            Height="50"
            Padding="8"
            Command="{Binding TagAllCommand}"
            CommandParameter="{x:Reference Name=wd}"
            Content="Tag by Category" />
    </Grid>
</Window>