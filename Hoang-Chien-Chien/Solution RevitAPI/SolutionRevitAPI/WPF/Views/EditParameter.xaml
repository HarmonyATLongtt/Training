<Window x:Class="SolutionRevitAPI.WPF.Views.EditParameter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SolutionRevitAPI.WPF.Views"
        mc:Ignorable="d"
        Width="400" Height="300" Name="wd" Title="Change Parameter Values" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DataGrid Grid.Row="0" CanUserAddRows="False" x:Name="dtgPara" ItemsSource="{Binding  ParameterElements}" AutoGenerateColumns="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Parameter" Binding="{Binding Name}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="Value" Binding="{Binding ValuePara}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
        <Button Grid.Row="1" Content="Save" Padding="8" Command="{Binding SaveCommand}" CommandParameter="{x:Reference Name=wd}"></Button>
    </Grid>
</Window>