<Window x:Class="test3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:test3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DataGrid Name="gridView" d:ItemsSource="{d:SampleData ItemCount=6}" Margin="0,0,211,0"/>
        <Button Name="btnOpen" Width="100" Height="30" Content="Open" HorizontalAlignment="Right" Margin="0,98,70,0" VerticalAlignment="Top" Click="btnOpen_Click"/>
        <Button Name="btnSave" Width="100" Height="30"  Content="Save" HorizontalAlignment="Right" Margin="0,217,70,0" VerticalAlignment="Top" Click="btnSave_Click"/>
        <Button Content="Clear" Name="btnClear" Width="100" Height="30" HorizontalAlignment="Right" Margin="0,342,70,0" VerticalAlignment="Top" Click="btnClear_Click"/>
    </Grid>
</Window>
